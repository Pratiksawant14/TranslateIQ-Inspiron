# Supabase PostgreSQL async connection string
SUPABASE_DATABASE_URL=postgresql+asyncpg://postgres:password@db.supabase.co:5432/postgres

# Qdrant vector database hostname
QDRANT_HOST=localhost

# Qdrant vector database port
QDRANT_PORT=6333

# Anthropic Claude API Key (using openrouter key per user requirement)
ANTHROPIC_API_KEY=sk-or-v1-...

# Qdrant Collection Name for Translation Memory
QDRANT_COLLECTION_NAME=translation_memory

# Application Environment (development, staging, production)
APP_ENV=development

# CORS Origins (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
